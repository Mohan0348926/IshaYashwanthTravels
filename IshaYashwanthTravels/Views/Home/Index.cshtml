@model IshaYaswanthTravels.Models.ContactViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Isha Yaswanth Travels</title>
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
</head>

<body>

    <header class="travel-header">
        <nav class="navbar navbar-expand-lg navbar-dark container">
            <a class="navbar-brand fw-bold fs-3" href="#">Isha Yaswanth Travels</a>
            <div class="ms-auto">
                <a href="#contact" class="btn btn-warning rounded-pill px-4">Contact Us</a>
            </div>
        </nav>
    </header>

    <section class="hero-section text-center text-white">
        <div class="container">
            <h1 class="display-4 fw-bold hero-title">Explore Your Journey With Us</h1>
            <p class="lead mt-3">
                Best travel services for tours, business trips, family trips and promotions.
            </p>
            <a href="#contact" class="btn btn-light btn-lg rounded-pill mt-4 px-5">
                Enquire Now
            </a>
        </div>
    </section>

    <section class="container py-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Our Services</h2>
            <p class="text-muted">Comfortable, safe and trusted travel solutions</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="service-card">
                    <h4>🚗 Cab Booking</h4>
                    <p>Local and outstation cab services with reliable drivers.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="service-card">
                    <h4>🚌 Group Trips</h4>
                    <p>Perfect travel planning for family, company and group tours.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="service-card">
                    <h4>🌍 Tour Packages</h4>
                    <p>Customized travel packages for holidays and business trips.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="contact-section py-5">
        <div class="container">
            <div class="contact-card mx-auto">

                <h2 class="text-center fw-bold mb-4">Contact Me</h2>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success text-center">
                        @TempData["Success"]
                    </div>
                }

                <form id="contactForm">

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input asp-for="Name" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Company</label>
                        <input asp-for="Company" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <input asp-for="Phone" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mail</label>
                        <input asp-for="Mail" type="email" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Message</label>

                        <textarea asp-for="Message"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Enter your travel enquiry here...">
                        </textarea>
                    </div>
                    <button type="submit"
                            id="submitBtn"
                            class="btn btn-primary w-100 rounded-pill">

                        <span id="btnText">Submit Enquiry</span>

                        <span id="btnSpinner"
                              class="spinner-border spinner-border-sm d-none ms-2">
                        </span>

                    </button>

                    <div id="successMessage"
                         class="alert alert-success text-center mt-3 d-none">

                        Enquiry sent successfully! We will contact you soon.

                    </div>

                </form>
            </div>
        </div>
    </section>

    <footer class="footer text-center text-white py-4">
        <p class="mb-1">© 2026 Isha Yaswanth Travels</p>
        <small>Safe Journey • Trusted Service • Best Promotions</small>
        <div> 
            <small>Design and Developed by Unique Mohan
            </small>
            </div>
    </footer>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script>
        $("#contactForm").submit(function (e) {
            e.preventDefault();

            $("#submitBtn").prop("disabled", true);
            $("#btnText").text("Sending...");
            $("#btnSpinner").removeClass("d-none");

            let formData = {
                Name: $("#Name").val(),
                Company: $("#Company").val(),
                Phone: $("#Phone").val(),
                Mail: $("#Mail").val(),
                Message: $("#Message").val()
            };

            $.ajax({
                url: '@Url.Action("Contact", "Home")',
                type: 'POST',
                data: formData,

                success: function (response) {
                    if (response.success) {
                        $("#successMessage")
                            .removeClass("d-none")
                            .html("Enquiry sent successfully! We will contact you soon.");

                        $("#btnText").text("Submitted");
                        $("#btnSpinner").addClass("d-none");

                        setTimeout(function () {
                            location.reload();
                        }, 5000);
                    }
                },

                error: function () {
                    $("#successMessage")
                        .removeClass("d-none alert-success")
                        .addClass("alert-danger")
                        .html("Something went wrong. Please try again.");

                    $("#btnText").text("Submit Enquiry");
                    $("#btnSpinner").addClass("d-none");
                    $("#submitBtn").prop("disabled", false);
                }
            });
        });
    </script>
</body>
</html>